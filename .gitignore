# Synthetic audio dataset — audio_tts WAVs ARE committed (dataset evidence for demo)
# Exclude only the older audio_dataset path if it exists
track_c_dataset/audio_dataset/*.wav
track_c_dataset/audio_dataset/*.mp3

# Eval run JSONs except the latest summary
track_d_eval/reports/eval_run_*.json
track_d_eval/reports/metrics_*.json

# User recordings and personal data — never commit
track_a_desktop/inputs/user_recordings/
track_a_desktop/feedback/
track_a_desktop/outputs/user_tests/

# Claude Code project files (agent state, not project code)
.claude/

